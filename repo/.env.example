POSTGRES_DB=harmonyhub
POSTGRES_USER=harmonyhub
POSTGRES_PASSWORD=harmonyhub_dev
DATABASE_URL=postgresql+psycopg2://harmonyhub:harmonyhub_dev@db:5432/harmonyhub

HH_ENVIRONMENT=development
HH_API_PREFIX=/api/v1
HH_LOG_LEVEL=INFO

# Local-development placeholder only. Must be overridden outside dev/test.
HH_JWT_SECRET=change-me-in-real-deployments
# Local-development placeholder only. Must be overridden outside dev/test.
HH_DATA_ENCRYPTION_KEY=dev-only-data-encryption-key
HH_JWT_EXPIRE_MINUTES=480
HH_PICKUP_CODE_TTL_SECONDS=300
HH_COOKIE_SECURE=true
HH_RATE_LIMIT_USER_PER_MIN=60
HH_RATE_LIMIT_IP_PER_MIN=300

HH_BOOTSTRAP_ADMIN_USERNAME=admin
# Local seeded credential only. Must be overridden outside dev/test.
HH_BOOTSTRAP_ADMIN_PASSWORD=admin123!

HH_EXPORT_DIR=/backup/exports
HH_BACKUP_DIR=/backup/runs
HH_BACKUP_OFFLINE_MEDIUM_DIR=/backup/offline-medium
HH_BACKUP_NIGHTLY_ENABLED=true
HH_BACKUP_NIGHTLY_HOUR_UTC=2
HH_AUDIT_RETENTION_DAYS=365
HH_RECOVERY_DRILL_INTERVAL_DAYS=90
HH_TRUSTED_PROXY_CIDRS=172.16.0.0/12

# Worker still uses this path variable.
HH_OFFLINE_BACKUP_MEDIUM_PATH=/backup/offline-medium
HH_WORKER_HEARTBEAT_SECONDS=30
HH_WORKER_BACKUP_CHECK_SECONDS=300
HH_WORKER_OPERATIONS_CHECK_SECONDS=3600

HH_CERT_CN=localhost
